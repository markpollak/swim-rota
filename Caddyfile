# Caddy reverse proxy. {$SITE_ADDRESS} comes from the environment (see .env):
#   - a domain (e.g. rota.thearc-matlock.co.uk) → automatic HTTPS via Let's Encrypt
#   - ":80" → plain HTTP on the droplet IP (fine for testing; PWA install needs HTTPS)
{$SITE_ADDRESS} {
	encode gzip

	# Security headers. HSTS only bites on HTTPS, so it's harmless on the IP-only
	# (:80) setup and protective once a domain + TLS is in place.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		# App uses external JS only (no inline scripts) but many inline style attrs.
		Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; manifest-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
		-Server
	}

	reverse_proxy app:8080
}
