# Copy to .env on the server and fill in.
# Your domain (gives automatic HTTPS). Point an A record at the droplet IP first.
SITE_ADDRESS=cmwebstats.com
# For IP-only testing without a domain, instead use:
# SITE_ADDRESS=:80

# --- Cloudflare-proxied mode (optional) ---
# To run behind Cloudflare's proxy (orange cloud) with an Origin Certificate,
# put the cert in ./certs/ and uncomment the next line. Leave it commented for the
# default direct / Let's Encrypt setup. See docs/LAUNCH-cmwebstats.md.
# CADDY_CONFIG=./Caddyfile.cloudflare

# Stable signing secret so staff stay logged in across redeploys.
# Generate one with:  openssl rand -base64 48
SWIM_SECRET=CHANGE_ME_to_a_long_random_string
